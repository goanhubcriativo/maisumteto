# ============================================================
#  BOLÃO TETO — variáveis de ambiente
#  Copie este arquivo para .env.local e preencha os valores.
# ============================================================

# ---- Banco de dados ----
# Local (SQLite): já funciona assim, não precisa mudar.
DATABASE_URL="file:./dev.db"
# Produção (Postgres/Neon/Vercel): troque para algo como:
# DATABASE_URL="postgresql://usuario:senha@host/db?sslmode=require"

# ---- Asaas ----
# Ambiente: "sandbox" (testes) ou "production" (real, dinheiro de verdade)
ASAAS_ENV="sandbox"
# Chave de API do Asaas (Configurações > Integrações > API).
# ATENÇÃO: use a chave do MESMO ambiente definido em ASAAS_ENV.
ASAAS_API_KEY="coloque_sua_api_key_aqui"
# Token que VOCÊ inventa e cadastra no webhook do Asaas (aba Webhooks).
# Serve para o sistema conferir que o webhook veio mesmo do Asaas.
ASAAS_WEBHOOK_TOKEN="invente_um_token_secreto_aqui"
# Grupo de clientes do Asaas para onde vão as cobranças desta campanha.
ASAAS_GRUPO="DOAÇÕES TETO PARANÁ"
# Taxa estimada por PIX (centavos), só usada até o valor líquido real chegar.
TAXA_PIX_ESTIMADA_CENTAVOS="99"

# ---- Painel admin ----
# Senha simples para acessar /admin. Troque por algo forte.
ADMIN_PASSWORD="troque-esta-senha"

# ---- Configuração do bolão ----
NEXT_PUBLIC_TIME_CASA="Seleção A"
NEXT_PUBLIC_TIME_VISITANTE="Seleção B"
NEXT_PUBLIC_DATA_JOGO="19/07/2026"
NEXT_PUBLIC_NOME_EVENTO="Bolão da Final da Copa — Casa Amiga de Dezembro (Teto)"
# Valor de cada aposta, em centavos (1000 = R$ 10,00)
VALOR_APOSTA_CENTAVOS="1000"
